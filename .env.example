# yclients API (получить в личном кабинете yclients → Интеграции → API)
YCLIENTS_PARTNER_TOKEN=
YCLIENTS_USER_TOKEN=
YCLIENTS_COMPANY_ID=

# Yandex Database (только для functions/submit, задаются в настройках Cloud Function)
YDB_ENDPOINT=grpcs://ydb.serverless.yandexcloud.net:2135
YDB_DATABASE=/ru-central1/xxxxxxxxxxxxxxxx/xxxxxxxxxxxxxxxx

# Tally-формы (legacy — использовались в v1 на FastAPI+Render, сейчас URL форм захардкожены в functions/identify/config.py)
TALLY_FORM_ACCOMPANYING=https://tally.so/r/...
TALLY_FORM_NEWBIE=https://tally.so/r/...
TALLY_FORM_REGULAR_ANON=https://tally.so/r/...
TALLY_FORM_REGULAR=https://tally.so/r/...
TALLY_FORM_LOYAL=https://tally.so/r/...
TALLY_FORM_CLIENT=https://tally.so/r/...
TALLY_FORM_HARD=https://tally.so/r/...
